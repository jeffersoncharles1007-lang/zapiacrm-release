# =============================================================================
# ZAPIACRM - .env.example (template de variaveis de ambiente)
# Copie para .env e preencha com valores reais.
# O instalador install-1click.sh cria o .env automaticamente com as credenciais.
# =============================================================================

# Nome do projeto (usado nos nomes dos containers Docker)
PROJECT_NAME=zapiacrm

# ===== BANCO DE DADOS =====
POSTGRES_DB=zapiacrm
POSTGRES_USER=admin
# Gerado automaticamente pelo instalador (32 caracteres aleatorios)
POSTGRES_PASSWORD=

# ===== PORTA DO APP =====
APP_PORT=4000

# ===== SUPABASE LOCAL (gerado automaticamente) =====
SUPABASE_URL=http://localhost:4000
SUPABASE_PROJECT_ID=internal
# Gerado automaticamente pelo instalador
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== GOOGLE OAUTH =====
# Fornecidos pelo desenvolvedor (mesmos para todos os clientes)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== EVOLUTION API (WhatsApp central) =====
# Fornecidos pelo desenvolvedor (mesmos para todos os clientes)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ===== CHAVES DE IA (cliente configura DEPOIS pelo painel) =====
# Deixe vazio - o cliente adiciona pelo painel em /master/painel
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=